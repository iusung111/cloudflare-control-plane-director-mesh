{
  "name": "cloudflare-control-plane-director-mesh",
  "version": "0.1.0",
  "description": "Cloudflare Control Plane Prototype",
  "main": "apps/worker/src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:ui": "vitest run tests/ui-components.test.ts",
    "test:load": "vitest run tests/load-chaos.test.ts --testNamePattern=\"load pack keeps\"",
    "test:chaos": "vitest run tests/load-chaos.test.ts --testNamePattern=\"chaos-lite retries\"",
    "test:e2e": "node tests/e2e/console-flow.mjs"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240101.0",
    "playwright": "^1.59.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3",
    "wrangler": "^4.81.0"
  }
}
